# Database
MONGODB_URI=

# Authentication
JWT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WebRTC Calls (self-hosted, no external media service required)
# Comma-separated STUN servers. Defaults to Google's free public STUN if empty.
STUN_URLS=
# Optional TURN relay (e.g. self-hosted coturn) for users behind strict NATs.
# Either set static credentials (TURN_USERNAME/TURN_CREDENTIAL), or set
# TURN_SECRET to your coturn `static-auth-secret` for time-limited credentials.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
TURN_SECRET=

# Email (Brevo SMTP)
BREVO_USER=
BREVO_SMTP_KEY=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Giphy
NEXT_PUBLIC_GIPHY_API_KEY=

GEMINI_API_KEY=
